# 复制本文件为 .env.local 并填写真实值（Next 只加载 .env.local，不加载本文件）

NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# 推荐：Project Settings → API → service_role（勿提交、勿暴露给浏览器）
SUPABASE_SERVICE_ROLE_KEY=

# 未配置 service role 时可使用 anon（需配置 RLS）
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# DeepSeek（OpenAI 兼容网关，见 lib/openai/deepseek.ts）
DEEPSEEK_API_KEY=
# 可选，默认 deepseek-chat
# DEEPSEEK_MODEL=deepseek-chat
